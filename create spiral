def spiralize(size):
  n = size-1
  checkpoints = [[1 for _ in range(size)]] + [[0 for _ in range(size)] for _ in range(n)]
  snake_coord = [0, n]
  travel = [1, -1]
  axis = 0

  while n >= 2:
    for path in range(2):
      axis = 0 if path == 0 else 1
      for step in range(n):
        snake_coord[axis] += travel[axis]
        checkpoints[snake_coord[0]][snake_coord[1]] = 1
      travel[axis] *= -1
      if path == 1:
        n -= 2
  if n == 1:
    axis = 0 if axis == 1 else 1
    snake_coord[axis] += travel[axis]
    checkpoints[snake_coord[0]][snake_coord[1]] = 1
  return checkpoints



